# ============================================================
# 多模态客服智能体 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ============================================================

# ========== API 认证 ==========
# Bearer Token，用于 /chat 等接口的身份验证
# 赛题要求: Authorization: Bearer {token}
API_TOKEN=sk_customer_20260304

# ========== LLM 主模型配置 ==========
# 支持: openai / local（Ollama）
LLM_PROVIDER=openai
# 主生成模型，推荐使用支持 vision 的模型
LLM_MODEL=deepseek-v4-pro
# OpenAI 兼容接口的 API Key
LLM_API_KEY=your_api_key_here
# OpenAI 兼容接口的 base URL
LLM_BASE_URL=https://cloud.infini-ai.com/maas/v1

# ========== Infini 官方接口（脚本默认读取） ==========
# 与上方 LLM_* 配置效果相同，脚本离线任务默认优先使用此处的 INFINI_* 配置
INFINI_API_KEY=your_api_key_here
INFINI_BASE_URL=https://cloud.infini-ai.com/maas/v1
INFINI_MODEL_ID=deepseek-v4-pro

# ========== Embedding / 向量化配置 ==========
# 向量模型名称
# 推荐: BAAI/bge-m3（1024维，中文+多语言最优）
# 轻量备选: moka-ai/m3e-base（768维）
EMBEDDING_MODEL=BAAI/bge-m3
# 推理设备: cpu / cuda
EMBEDDING_DEVICE=cuda

# HuggingFace 模型缓存路径（建议放在 D 盘避免占满系统盘）
# HF_HOME=D:/models/huggingface

# ========== RAG 检索配置 ==========
# 基础召回数（每个子问题独立检索时）
RAG_TOP_K=8
# 检索相关性阈值，低于此值的结果不返回
RAG_SCORE_THRESHOLD=0.35
# 是否启用 BGE 交叉编码器重排序
RAG_ENABLE_RERANKER=true
# 是否启用 dense+sparse 混合检索（BGE-M3 内置支持）
ENABLE_HYBRID_RETRIEVAL=true
# sparse 分数权重，dense_weight = 1 - sparse_weight
HYBRID_SPARSE_WEIGHT=0.3

# ========== 拼写纠错配置（可选） ==========
# 启用 LLM 驱动的拼写纠错，可提升检索召回率
SPELL_CORRECTION_ENABLED=false

# ========== 幻觉抑制配置 ==========
# 是否启用幻觉检测
HALLUCINATION_DETECTION_ENABLED=true
# 是否启用思维链推理
ENABLE_COT_REASONING=true

# ========== 会话配置 ==========
# 最大保留对话历史轮数
MAX_CONVERSATION_HISTORY=10
# 会话超时时间（秒）
SESSION_TIMEOUT=3600

# ========== 日志配置 ==========
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ========== 启动配置（可选） ==========
# 是否在服务启动时预加载 RAG 引擎（预加载会延长启动时间，但首次请求更快）
EAGER_INIT_RAG=false
# 是否在服务启动时预加载多模态理解模块
EAGER_INIT_MULTIMODUAL=false
# 是否在服务启动时预加载回答生成器
EAGER_INIT_RESPONSE_GENERATOR=false

# ========== 多模态理解配置（可选） ==========
# 是否启用多模态图片理解
ENABLE_VISION_MODEL=false
# 是否启用结构化多模态理解（传入路由和分解器）
MULTIMODAL_UNDERSTANDING_ENABLED=true

# ========== 双路检索配置（可选） ==========
# 路由分类器是否启用（可降级为纯规则路由）
ROUTE_CLASSIFIER_ENABLED=true
# 是否在手册检索时启用局部召回优化
ROUTE_MANUAL_LOCAL_RECALL_ENABLED=true

# ========== API 服务配置（可选） ==========
# API 服务监听地址
# API_HOST=0.0.0.0
# API_PORT=8000
